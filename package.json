{
  "name": "molecules",
  "version": "2026.7.7",
  "description": "JavaScript cheminformatics toolkit for molecular graphs, SMILES/InChI, SMARTS/SMIRKS, 2D layout, and molecular descriptors",
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./es/index.js",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./lib/index.js",
      "default": "./es/index.js"
    },
    "./core": {
      "import": "./src/core/index.js"
    },
    "./algorithms": {
      "import": "./src/algorithms/index.js"
    },
    "./matrices": {
      "import": "./src/matrices/index.js"
    },
    "./descriptors": {
      "import": "./src/descriptors/index.js"
    },
    "./data": {
      "import": "./src/data/index.js"
    },
    "./io": {
      "import": "./src/io/index.js"
    },
    "./layout": {
      "import": "./src/layout/index.js"
    },
    "./smarts": {
      "import": "./src/smarts/index.js"
    },
    "./smirks": {
      "import": "./src/smirks/index.js"
    },
    "./utils": {
      "import": "./src/utils/index.js"
    },
    "./validation": {
      "import": "./src/validation/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "es",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "clean": "rimraf lib es dist",
    "prebuild": "npm run clean",
    "test": "node --test 'tests/**/*.test.js'",
    "test:layout:browser": "RUN_BROWSER_LAYOUT_TESTS=1 node --test tests/layout/engine/browser-determinism.test.js",
    "test:layout:stress": "RUN_LAYOUT_STRESS=1 node --test 'tests/layout/engine/**/*.test.js'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "node --test --watch 'tests/**/*.test.js'",
    "test:coverage": "node --test --experimental-test-coverage 'tests/**/*.test.js'",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs": "rm -rf docs/api && jsdoc -c jsdoc.json",
    "prepublishOnly": "npm run lint && npm run build && npm run test"
  },
  "keywords": [
    "chemistry",
    "cheminformatics",
    "computational-chemistry",
    "molecule",
    "molecular-graph",
    "smiles",
    "inchi",
    "smarts",
    "smirks",
    "molecular-descriptors",
    "graph-theory",
    "drug-discovery",
    "qsar",
    "chemdraw"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "clean-jsdoc-theme": "^5.0.7",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.12",
    "globals": "^17.7.0",
    "jsdoc": "^4.0.3",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2"
  }
}
